{
  "name": "PasBan Authenticator",
  "description": "نگهبان امن و آفلاین اکانت‌های شما",
  "version": "1.0.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html",
    "default_icon": "icons/pasbanlogo.png"
  },
  "icons": {
    "16": "icons/pasbanlogo.png",
    "48": "icons/pasbanlogo.png",
    "128": "icons/pasbanlogo.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}